---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "Nutri Valley - Υγιεινές και απολαυστικές επιλογές για όλες τις ηλικίες" } = Astro.props;
---
<!DOCTYPE html>
<html lang="el">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=1920" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="preload" as="font" type="font/woff2" href="/fonts/tiktoksans-greek.woff2" crossorigin />
    <link rel="preload" as="font" type="font/woff2" href="/fonts/tiktoksans-latin.woff2" crossorigin />
    <link rel="icon" type="image/webp" href="/img/path-51-1@1x.webp" />
    <link rel="preload" as="image" type="image/webp" href="/img/group-31-1@1x.webp" fetchpriority="high" />
    <link rel="preload" as="image" type="image/webp" href="/img/group-31@1x.webp" />
  </head>
  <body>
    <main>
      <slot />
    </main>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
