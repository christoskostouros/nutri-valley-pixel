---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "Nutri Valley - Υγιεινές και απολαυστικές επιλογές για όλες τις ηλικίες" } = Astro.props;
---
<!DOCTYPE html>
<html lang="el">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=1920" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=TikTok+Sans:wght@400;500;700&subset=greek&display=swap" rel="stylesheet" />
    <link rel="icon" type="image/webp" href="/img/path-51-1@1x.webp" />
    <link rel="preload" as="image" type="image/webp" href="/img/group-31@1x.webp" fetchpriority="high" />
    <link rel="preload" as="image" type="image/webp" href="/img/group-31-1@1x.webp" />
  </head>
  <body>
    <main>
      <slot />
    </main>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
