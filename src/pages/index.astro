---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Nutri Valley - Υγιεινές επιλογές για όλη την οικογένεια">
  <div class="page-wrapper">
    <!-- ===== STICKY NAVBAR ===== -->
    <div class="navbar-wrapper" id="navbarWrapper">
      <div class="navbar">
        <!-- Green Products Button -->
        <div class="navbar__products-btn" id="productsBtn">
          <div class="navbar__hamburger">
            <span></span>
            <span></span>
          </div>
          <span class="navbar__products-label">ΠΡΟΪΟΝΤΑ</span>
        </div>

        <!-- Center White Pill -->
        <div class="navbar__center-pill">
          <a href="/" class="navbar__logo">
            <img class="navbar__logo-leaf" src="/img/path-51-1@1x.webp" alt="Nutri Valley Leaf" />
            <img class="navbar__logo-text" src="/img/group-33-1@1x.webp" alt="Nutri Valley" />
            <img class="navbar__logo-dot" src="/img/path-50@1x.webp" alt="" />
          </a>
          <div class="navbar__links">
            <a href="#recipes" class="navbar__link">ΣΥΝΤΑΓΕΣ</a>
            <a href="#" class="navbar__link">ΔΙΑΓΩΝΙΣΜΟΙ</a>
            <a href="#events" class="navbar__link">EVENTS</a>
            <a href="#blog" class="navbar__link">BLOG</a>
            <a href="#about" class="navbar__link">ΣΧΕΤΙΚΑ</a>
            <a href="#contact" class="navbar__link">ΕΠΙΚΟΙΝΩΝΙΑ</a>
          </div>
        </div>

        <!-- Globe/Language Button -->
        <div class="navbar__circle-btn navbar__circle-btn--globe">
          <div class="globe-icon">
            <div class="globe-icon__circle"></div>
            <img class="globe-icon__vert1" src="/img/path-64-1@1x.webp" alt="" />
            <img class="globe-icon__vert2" src="/img/path-65-1@1x.webp" alt="" />
            <img class="globe-icon__horiz1" src="/img/line-12-1@1x.webp" alt="" />
            <img class="globe-icon__horiz2" src="/img/line-12-1@1x.webp" alt="" />
          </div>
        </div>

        <!-- Search Button -->
        <div class="navbar__circle-btn navbar__circle-btn--search">
          <div class="search-icon">
            <img class="search-icon__line" src="/img/line-11-1@1x.webp" alt="" />
          </div>
        </div>
      </div>
    </div>

    <!-- Mega Menu Overlay -->
    <div class="mega-menu-overlay" id="megaOverlay"></div>

    <!-- Mega Menu -->
    <div class="mega-menu" id="megaMenu">
      <div class="mega-menu__left">
        <div class="mega-menu__category active" data-category="adults">
          <span class="mega-menu__category-name">ΠΡΟΪΟΝΤΑ ΓΙΑ ΕΝΗΛΙΚΕΣ</span>
          <img class="mega-menu__arrow" src="/img/path-36@1x.webp" alt="" />
        </div>
        <div class="mega-menu__category" data-category="kids" style="margin-top: 20px;">
          <span class="mega-menu__category-name">ΠΑΙΔΙΚΑ ΠΡΟΪΟΝΤΑ</span>
          <img class="mega-menu__arrow" src="/img/path-36@1x.webp" alt="" />
        </div>
        <div class="mega-menu__subcategories" id="megaSubcats">
          <div class="mega-menu__subcat-column">
            <a href="#">Premium Κονσέρβες</a>
            <a href="#">Μπάρες Πρωτεΐνης</a>
            <a href="#">Γκοφρέτες</a>
            <a href="#">Ταχίνι</a>
          </div>
          <div class="mega-menu__subcat-column">
            <a href="#">Γκρανόλα</a>
            <a href="#">Νιφάδες Βρώμης</a>
            <a href="#">Νιφάδες Καλαμποκιού</a>
