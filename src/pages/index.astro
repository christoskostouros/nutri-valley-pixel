              <img class="kids-card__logo" src="/img/logo-pjmasks@1x.webp" alt="PJ Masks" />
            </div>
            <div class="kids-card">
              <div class="kids-card__img" style="background-image: url('/img/kids-card-minions@1x.webp');"></div>
              <img class="kids-card__logo" src="/img/logo-minions@1x.webp" alt="Minions" />
            </div>
            <div class="kids-card">
              <div class="kids-card__img" style="background-image: url('/img/kids-card-scooby@1x.webp');"></div>
              <img class="kids-card__logo" src="/img/logo-scooby@1x.webp" alt="Scooby-Doo" />
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- ===== HERO SECTION ===== -->
    <section class="hero-section">
      <div class="hero-slider">
