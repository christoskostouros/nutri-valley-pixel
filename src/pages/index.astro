  <script>
    // Hero Slider
    const heroTrack = document.getElementById('heroTrack');
    const heroLeft = document.getElementById('heroLeft');
    const heroRight = document.getElementById('heroRight');
    let currentSlide = 0;

    function goToSlide(index) {
      currentSlide = index;
      heroTrack.className = `hero-slider__track slide-${index + 1}`;
    }

    heroRight?.addEventListener('click', () => {
      goToSlide(currentSlide === 0 ? 1 : 0);
    });

    heroLeft?.addEventListener('click', () => {
      goToSlide(currentSlide === 0 ? 1 : 0);
    });

    // Auto-slide every 5 seconds
    setInterval(() => {
      goToSlide(currentSlide === 0 ? 1 : 0);
    }, 5000);

    // Mega Menu
    const productsBtn = document.getElementById('productsBtn');
    const megaMenu = document.getElementById('megaMenu');
    const megaOverlay = document.getElementById('megaOverlay');

    function toggleMegaMenu() {
      const isActive = megaMenu.classList.contains('active');
      if (isActive) {
        megaMenu.classList.remove('active');
        megaOverlay.classList.remove('active');
        productsBtn.classList.remove('active');
      } else {
        megaMenu.classList.add('active');
        megaOverlay.classList.add('active');
        productsBtn.classList.add('active');
      }
    }

    productsBtn?.addEventListener('click', toggleMegaMenu);
    megaOverlay?.addEventListener('click', () => {
      megaMenu.classList.remove('active');
      megaOverlay.classList.remove('active');
      productsBtn.classList.remove('active');
    });

    // Close mega menu when clicking outside it
    document.addEventListener('click', (e) => {
      if (megaMenu.classList.contains('active')) {
        if (!megaMenu.contains(e.target) && !productsBtn.contains(e.target)) {
          megaMenu.classList.remove('active');
          megaOverlay.classList.remove('active');
          productsBtn.classList.remove('active');
        }
      }
    });

    // Mega menu category hover
    const categories = document.querySelectorAll('.mega-menu__category');
    const megaRightAdults = document.getElementById('megaRightAdults');
    const megaRightKids = document.getElementById('megaRightKids');
    const megaSubcats = document.getElementById('megaSubcats');

    categories.forEach(cat => {
      cat.addEventListener('mouseenter', () => {
        categories.forEach(c => c.classList.remove('active'));
        cat.classList.add('active');
        const isKids = cat.dataset.category === 'kids';
        if (megaRightAdults) megaRightAdults.style.display = isKids ? 'none' : 'block';
        if (megaRightKids) megaRightKids.style.display = isKids ? 'block' : 'none';
        if (megaSubcats) megaSubcats.style.display = isKids ? 'none' : 'flex';
      });
    });

    // Adult Products Slider Arrows
    const adultCards = document.getElementById('adultCards');
    const adultLeft = document.getElementById('adultLeft');
    const adultRight = document.getElementById('adultRight');
    const scrollAmount = 350;

    adultRight?.addEventListener('click', () => {
      adultCards?.scrollBy({ left: scrollAmount, behavior: 'smooth' });
    });

    adultLeft?.addEventListener('click', () => {
      adultCards?.scrollBy({ left: -scrollAmount, behavior: 'smooth' });
    });

    // Lazy load background images via Intersection Observer
    const lazyBgs = document.querySelectorAll('[data-bg]');
    const bgObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const el = entry.target;
          el.style.backgroundImage = `url('${el.dataset.bg}')`;
          el.removeAttribute('data-bg');
          bgObserver.unobserve(el);
        }
      });
    }, { rootMargin: '200px' });
    lazyBgs.forEach(el => bgObserver.observe(el));

    // Smooth scroll for anchor links
    document.querySelectorAll('a[href^="#"]').forEach(anchor => {
      anchor.addEventListener('click', function (e) {
        const target = document.querySelector(this.getAttribute('href'));
        if (target) {
          e.preventDefault();
          target.scrollIntoView({ behavior: 'smooth' });
        }
      });
    });
  </script>
</Layout>
