      <div class="mega-menu__right" id="megaRight">
        <!-- Adults content -->
        <div class="mega-right__adults" id="megaRightAdults">
          <img src="/img/group-25@1x.webp" alt="Nutri Valley Products" />
        </div>
        <!-- Kids content -->
        <div class="mega-right__kids" id="megaRightKids" style="display: none;">
          <div class="kids-cards-row">
            <div class="kids-card">
              <div class="kids-card__img" style="background-image: url('/img/kids-card-peppa@1x.webp');"></div>
              <img class="kids-card__logo" src="/img/logo-peppa@1x.webp" alt="Peppa Pig" />
            </div>
            <div class="kids-card">
